---
source: src/themes/css.rs
expression: "generate_css(&theme, \"g-\")"
---
/*
 * theme "vitesse-black" generated by giallo
 */

.g-code {
  color: #DBD7CACC;
  background-color: #000000;
}

.g-hl {
  background-color: #121212;
}

.giallo-ln {
  color: #DEDCD550;
}

